# Dependency directories
node_modules/

# Local env files (MUST be ignored)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#testing-plugins)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation files (https://github.com/nodejs/node-gyp)
build/Release

# Dependency directories for electron and nwjs
node_modules/
jspm_packages/

# TypeScript v1.x command line compiler target and typescript headers
# typings/

# TypeScript cache
.tscache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional microbundle cache
.rts2_cache_http

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-cache
.cache
.parcel-cache

# Temporary files
.DS_Store
Thumbs.db
